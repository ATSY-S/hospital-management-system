<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hy.mapper.SysHelpDocMapper" >
    <select id="findByPage" resultType="com.hy.pojo.SysHelpDoc">
        SELECT * FROM sys_help_doc
        <where>
            status = 1
            <if test="category != null and category != ''">AND category = #{category}</if>
        </where>
        ORDER BY sort_order LIMIT #{offset}, #{size}
    </select>
    <select id="countByCategory" resultType="java.lang.Long">
        SELECT COUNT(*) FROM sys_help_doc
        <where>
            status = 1
            <if test="category != null and category != ''">AND category = #{category}</if>
        </where>
    </select>
    <select id="findById" resultType="com.hy.pojo.SysHelpDoc">
        SELECT * FROM sys_help_doc WHERE id = #{id}
    </select>
</mapper>
